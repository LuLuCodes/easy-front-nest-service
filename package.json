{
  "name": "easy-front-nest-service",
  "version": "5.0.0",
  "description": "基于 NestJS 的后端 API Service 框架",
  "author": "qian.qing@aliyun.com",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "bootstrap": "pnpm install",
    "prebuild": "rimraf api",
    "build": "rimraf api && nest build && shx cp ./src/.env.production ./api/.env",
    "build:prod": "rimraf api && nest build && shx cp ./src/.env.production ./api/.env",
    "build:pre-release": "rimraf api && nest build && shx cp ./src/.env.pre-release ./api/.env",
    "build:test": "rimraf api && nest build && shx cp ./src/.env.test ./api/.env",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "rimraf api && cross-env NODE_ENV=development nest start --watch",
    "start:debug": "rimraf api && cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "node api/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "node --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "migration:generate": "pnpm typeorm migration:generate",
    "migration:run": "pnpm typeorm migration:run",
    "migration:revert": "pnpm typeorm migration:revert",
    "cz": "git-cz",
    "ncu": "ncu -u",
    "prepare": "husky"
  },
  "dependencies": {
    "@alicloud/pop-core": "^1.7.13",
    "@easy-front-core-sdk/kits": "^1.5.4",
    "@easy-front-core-sdk/wxpay": "^1.5.4",
    "@inquirer/prompts": "^4.3.0",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/serve-static": "^4.0.1",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "ali-oss": "^6.23.0",
    "axios": "^1.16.0",
    "bignumber.js": "^9.1.2",
    "body-parser": "^1.20.2",
    "body-parser-xml": "^2.0.5",
    "bullmq": "^5.76.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "commander": "^12.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cross-env": "^7.0.3",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.20",
    "dotenv": "^16.4.5",
    "easy-front-core-sdk": "^1.5.4",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "fast-xml-parser": "^4.3.6",
    "form-data": "^4.0.5",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsdom": "^25.0.1",
    "lodash": "^4.17.21",
    "mathjs": "^13.0.3",
    "minimist": "^1.2.8",
    "multer": "1.4.5-lts.1",
    "mysql2": "^3.9.2",
    "nestjs-ali-oss": "^1.0.0",
    "nestjs-pino": "^4.6.1",
    "nestjs-throttler-storage-redis": "^0.5.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redlock": "5.0.0-beta.2",
    "reflect-metadata": "^0.2.1",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "uuid": "^9.0.1",
    "vm": "^0.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.13.0",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.4",
    "@swc/cli": "^0.5.0",
    "@swc/core": "^1.7.36",
    "@types/ali-oss": "^6.23.3",
    "@types/body-parser": "^1.19.5",
    "@types/body-parser-xml": "^2.0.5",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.13",
    "@types/lodash": "^4.17.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.18",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "@types/validator": "^13.12.2",
    "commitizen": "^4.3.1",
    "commitlint-config-cz": "^0.13.3",
    "cz-conventional-changelog": "^3.3.0",
    "cz-customizable": "^7.5.4",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "nock": "^14.0.15",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "shx": "^0.4.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "webpack": "^5.95.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "moduleNameMapper": {
      "@auth/(.*)": "<rootDir>/src/auth/$1",
      "@common/(.*)": "<rootDir>/src/common/$1",
      "@config/(.*)": "<rootDir>/src/config/$1",
      "@database/(.*)": "<rootDir>/src/database/$1",
      "@entities/(.*)": "<rootDir>/src/entities/$1",
      "@service/(.*)": "<rootDir>/src/service/$1",
      "@libs/(.*)": "<rootDir>/src/libs/$1",
      "@modules/(.*)$": "<rootDir>/src/modules/$1",
      "@pipe/(.*)$": "<rootDir>/src/pipe/$1",
      "@filter/(.*)$": "<rootDir>/src/filter/$1",
      "@dto/(.*)$": "<rootDir>/src/dto/$1",
      "@guard/(.*)$": "<rootDir>/src/guard/$1",
      "@decorator/(.*)$": "<rootDir>/src/decorator/$1",
      "@tenant/(.*)$": "<rootDir>/src/tenant/$1",
      "@providers/(.*)$": "<rootDir>/src/providers/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/api/",
      ".*\\.integration\\.spec\\.ts$"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/**/*.dto.ts",
      "!src/**/index.ts",
      "!src/main.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  }
}

{
  "name": "easy-front-nest-service",
  "version": "5.0.0",
  "description": "基于 NestJS 的后端 API Service 框架",
  "author": "qian.qing@aliyun.com",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "bootstrap": "pnpm install",
    "prebuild": "rimraf api",
    "build": "rimraf api && nest build && shx cp ./src/.env.production ./api/.env",
    "build:prod": "rimraf api && nest build && shx cp ./src/.env.production ./api/.env",
    "build:pre-release": "rimraf api && nest build && shx cp ./src/.env.pre-release ./api/.env",
    "build:test": "rimraf api && nest build && shx cp ./src/.env.test ./api/.env",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "rimraf api && cross-env NODE_ENV=development nest start --watch",
    "start:debug": "rimraf api && cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "node api/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --config ./test/jest-integration.json --forceExit",
    "typeorm": "node --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "migration:generate": "pnpm typeorm migration:generate",
    "migration:run": "pnpm typeorm migration:run",
    "migration:revert": "pnpm typeorm migration:revert",
    "cz": "git-cz",
    "ncu": "ncu -u",
    "prepare": "husky"
  },
  "dependencies": {
    "@alicloud/pop-core": "^1.7.13",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@inquirer/prompts": "^4.3.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "ali-oss": "^6.23.0",
    "alipay-sdk": "^4.14.0",
    "axios": "^1.16.0",
    "bullmq": "^5.76.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "commander": "^12.0.0",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.20",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.5",
    "ioredis": "^5.10.1",
    "lodash": "^4.17.21",
    "mathjs": "^13.0.3",
    "minimist": "^1.2.8",
    "mysql2": "^3.9.2",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redlock": "5.0.0-beta.2",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^9.13.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.5.0",
    "@swc/core": "^1.7.36",
    "@types/ali-oss": "^6.23.3",
    "@types/body-parser": "^1.19.5",
    "@types/body-parser-xml": "^2.0.5",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/crypto-js": "^4.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.13",
    "@types/lodash": "^4.17.10",
    "@types/node": "^22.19.18",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "@types/validator": "^13.12.2",
    "commitizen": "^4.3.1",
    "commitlint-config-cz": "^0.13.3",
    "cz-conventional-changelog": "^3.3.0",
    "cz-customizable": "^7.5.4",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.4",
    "nock": "^14.0.15",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "webpack": "^5.95.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "moduleNameMapper": {
      "@auth/(.*)": "<rootDir>/src/auth/$1",
      "@common/(.*)": "<rootDir>/src/common/$1",
      "@config/(.*)": "<rootDir>/src/config/$1",
      "@database/(.*)": "<rootDir>/src/database/$1",
      "@entities/(.*)": "<rootDir>/src/entities/$1",
      "@service/(.*)": "<rootDir>/src/service/$1",
      "@libs/(.*)": "<rootDir>/src/libs/$1",
      "@modules/(.*)$": "<rootDir>/src/modules/$1",
      "@pipe/(.*)$": "<rootDir>/src/pipe/$1",
      "@filter/(.*)$": "<rootDir>/src/filter/$1",
      "@dto/(.*)$": "<rootDir>/src/dto/$1",
      "@guard/(.*)$": "<rootDir>/src/guard/$1",
      "@decorator/(.*)$": "<rootDir>/src/decorator/$1",
      "@tenant/(.*)$": "<rootDir>/src/tenant/$1",
      "@providers/(.*)$": "<rootDir>/src/providers/$1",
      "@interceptor/(.*)$": "<rootDir>/src/interceptor/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/api/",
      ".*\\.integration\\.spec\\.ts$"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/**/*.dto.ts",
      "!src/**/index.ts",
      "!src/main.ts"
    ],
    "coverageDirectory": "./coverage",
    "coverageThreshold": {
      "global": {
        "statements": 50,
        "branches": 35,
        "functions": 50,
        "lines": 50
      }
    },
    "testEnvironment": "node"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  },
  "pnpm": {
    "overrides": {
      "cross-spawn": "^7.0.6",
      "fast-uri": "^3.1.2",
      "fastify": "^5.8.5",
      "validator": "^13.15.22"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@swc/cli>chokidar": "4"
      }
    }
  }
}

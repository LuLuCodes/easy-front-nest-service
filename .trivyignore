# Trivy allowlist for HIGH/CRITICAL findings the gate cannot fix in P6.
# Each entry must reference a tracking note + revisit trigger.
#
# Format: one CVE per line. Comments allowed via leading `#`.

# ─── lodash future-dated CVE referencing non-existent fix version ───────
# Trivy reports fix in 4.18.0 which has not been published. Re-evaluate
# when that version exists upstream.
CVE-2026-4800

# ─── glob / minimatch transitive (jest coverage path) ───────────────────
# Forcing glob ^10.5 and minimatch ^9.0.7 breaks jest's coverage chain
# (test-exclude@6 → babel-plugin-istanbul) because those versions ship as
# ESM-only named exports while the consumer expects the legacy CommonJS
# function shape. Revisit when jest 30 lands or test-exclude/babel
# updates upstream.
CVE-2025-64756    # glob 10.4.5
CVE-2026-26996    # minimatch 9.0.5
CVE-2026-27903    # minimatch 9.0.5
CVE-2026-27904    # minimatch 9.0.5

# ─── Distroless base image (gcr.io/distroless/nodejs22-debian12) ────────
# OpenSSL 3.0.18-1~deb12u2 → 3.0.19-1~deb12u2 fix is upstream but the
# distroless image hasn't rebuilt yet. These clear automatically next
# time the workflow rebuilds the runner stage from a refreshed base.
CVE-2026-31789    # CRITICAL libssl3
CVE-2026-28387    # HIGH libssl3
CVE-2026-28388    # HIGH libssl3
CVE-2026-28389    # HIGH libssl3
